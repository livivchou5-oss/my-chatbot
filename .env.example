# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# FACEBOOK
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ចូល developers.facebook.com → App → Messenger → Page Access Token
FB_PAGE_TOKEN=your_facebook_page_access_token_here

# Token ដែលអ្នកនឹង Set នៅ Facebook Webhook (តម្លៃអ្វីក៏បានដែលអ្នកចង់)
FB_VERIFY_TOKEN=my_secret_verify_token_2024

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# TELEGRAM
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ចូល Telegram → @BotFather → /newbot → copy token
TELEGRAM_BOT_TOKEN=7123456789:AAExxxxxxxxxxxxxxxxxxxxxx

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# GEMINI AI (ឥតគិតថ្លៃ!)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ចូល https://aistudio.google.com/apikey → Create API Key → Copy
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxx
